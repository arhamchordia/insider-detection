# Copy to .env and fill in your values.

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5433/insider_detection

# Log level (trace | debug | info | warn | error)
RUST_LOG=insider_detection=info

# Polymarket Data API key (required)
POLYMARKET_API_KEY=YOUR_KEY_HERE

# API base URLs (optional — uncomment to override defaults)
# POLYMARKET_DATA_API_URL=https://data-api.polymarket.com
# POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
# GOLDSKY_SUBGRAPH_URL=https://api.goldsky.com/api/public/project_cl6mb8i9h0003e201j6li0diw/subgraphs/orderbook-subgraph/0.0.1/gn

# Scan window
# SCAN_WINDOW_FROM     Unix timestamp — start of first window (default: now at startup)
# SCAN_WINDOW_TO       Unix timestamp — omit for perpetual real-time mode
# POLL_INTERVAL_SECS   Seconds between polls in perpetual mode (default: 60)
#
# Fixed window (analyze a historical case):
# SCAN_WINDOW_FROM=1759017600
# SCAN_WINDOW_TO=1761350399
#
# Perpetual mode (real-time monitoring from a known start):
# SCAN_WINDOW_FROM=1759017600
# POLL_INTERVAL_SECS=60
